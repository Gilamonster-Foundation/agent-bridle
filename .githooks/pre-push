#!/usr/bin/env bash
# agent-bridle pre-push hook — the local equivalent of CI gates.
#
# PIPELINE PARITY: this hook mirrors .github/workflows/ci.yml and the `check`
# recipe in justfile. When editing the lint/format/test steps here, verify it
# still matches the CI workflow and the justfile (HOOK PARITY rule).
#
# Do NOT bypass with --no-verify. If this fails, fix the issue.

set -euo pipefail

echo "[pre-push] running 'just check' (fmt + clippy -D warnings + tests, full matrix)"
just check

echo "[pre-push] running coverage gate (skips gracefully if cargo-llvm-cov absent)"
just cov-ci

echo "[pre-push] OK"
