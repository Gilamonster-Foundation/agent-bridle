  (f : boundary.Fence) (q : boundary.Request) : Result authority.Effect := do
  match f with
  | boundary.Fence.Advisory => boundary.safe_subset q
  | boundary.Fence.Kernel => boundary.brush_honest boundary.Fence.Kernel q

