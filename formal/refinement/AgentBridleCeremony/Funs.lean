    Visibility: public -/
def boundary.brush_honest
  (f : boundary.Fence) (q : boundary.Request) : Result authority.Effect := do
  match f with
  | boundary.Fence.Advisory =>
    if q.dynamic
    then ok authority.Effect.Deny
    else ok authority.Effect.Allow
  | boundary.Fence.Kernel => ok authority.Effect.Allow

